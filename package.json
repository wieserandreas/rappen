{
  "name": "rappen",
  "private": true,
  "description": "Rappen – Präzision auf den letzten Rappen. 10 B2B APIs for Swiss companies.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:cantons": "vitest run --project swiss-data -- cantons",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "validate:cantons": "tsx scripts/validate-all-cantons.ts",
    "db:migrate": "turbo db:migrate --filter=@rappen/db",
    "db:studio": "turbo db:studio --filter=@rappen/db",
    "format": "biome format --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "decimal.js": "^10.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
